# Dependencias
node_modules/

# Credenciais - NUNCA suba isso pro GitHub
.env
config/secrets.json

# Atalhos e configuracoes pessoais (caminhos locais do seu PC) - fica so na sua maquina.
# config/launcher.example.json (o template) continua versionado.
config/launcher.json
config/cabotagemConfig.json
config/schedule.json
config/navios.json

# Dados baixados da planilha (tem informacao interna da empresa)
data/downloads/*
!data/downloads/.gitkeep
data/cache/*
!data/cache/.gitkeep

# Suas notas e agenda - conteudo pessoal, fica so na sua maquina
data/notas.json

# CT-e (CZAR) - ambiente Python e dados processados (documentos internos).
# As subpastas de "data" e "processados" sao recriadas sozinhas pelo programa.
cte-czar/venv/
cte-czar/**/__pycache__/
cte-czar/data/
cte-czar/processados/
cte-czar/downloads/
cte-czar/**/*.pkl
cte-czar/regiao_do_numero.png
# vinculos.json guarda caminhos de pasta locais por armador - fica so na sua maquina
cte-czar/config/vinculos.json

# Planilhas de dados reais que voce coloca direto na pasta do projeto -
# nunca vao pro Git (dados internos/financeiros da empresa)
PLANILHAS BASE/

# Logs
*.log
logs/

# Playwright
test-results/
playwright-report/

# SO / editores
.DS_Store
Thumbs.db
.vscode/
*.swp
