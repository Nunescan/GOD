# Copie este arquivo para ".env" (mesma pasta) e preencha com seus dados.
# O arquivo ".env" NUNCA e enviado ao GitHub (esta no .gitignore).

# --- Login no Ravex ---
RAVEX_URL=https://longopercurso.sistema.ravex.com.br/login
RAVEX_USERNAME=seu.email@seara.com.br
RAVEX_PASSWORD=sua_senha_aqui

# --- Comportamento da automacao ---
# true = roda o navegador escondido (recomendado no dia a dia)
# false = mostra o navegador abrindo (util para testar/depurar)
RAVEX_HEADLESS=true

# A cada quantos minutos a automacao deve rodar sozinha e atualizar os dados
AUTO_REFRESH_MINUTES=10

# --- Servidor local ---
PORT=4173
